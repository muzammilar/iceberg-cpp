        <name>VFormat</name>
        <qualifiedname>iceberg::internal::VFormat</qualifiedname>
        <param>
          <type>std::string_view</type>
          <declname>fmt</declname>
        </param>
        <param>
          <type>Args &amp;&amp;...</type>
          <declname>args</declname>
